{
  "name": "package-version-info",
  "version": "0.2.3",
  "author": {
    "name": "Dominik Hladík",
    "email": "dominik.hladik@seznam.cz",
    "url": "https://github.com/Celtian"
  },
  "license": "MIT",
  "private": false,
  "description": "Generate version info from package.json for TypeScript projects",
  "scripts": {
    "validate": "yarn format:check && yarn test:launcher && yarn build && yarn test",
    "format:check": "zig fmt --check src/root.zig src/main.zig src/cli.zig build.zig",
    "build": "zig build",
    "build:platforms": "yarn script:package-zig && yarn tsx ./scripts/build-platforms.ts",
    "start": "zig build run",
    "test": "zig build test",
    "test:launcher": "node --test ./scripts/package-version-info.test.cjs",
    "test:package": "yarn tsx ./scripts/verify-package.ts",
    "coverage:build": "rimraf coverage zig-out/coverage-tests && zig build coverage",
    "clean": "rimraf zig-out dist",
    "prepare": "husky",
    "package": "yarn build:platforms && yarn script:package-npm && yarn test:package",
    "postinstall": "yarn script:package-zig",
    "script:package-zig": "yarn tsx ./scripts/package-zig.ts",
    "script:package-npm": "yarn tsx ./scripts/package-npm.ts",
    "script:package-github": "yarn tsx ./scripts/package-github.ts",
    "version": "auto-changelog -p && git add CHANGELOG.md",
    "postversion": "git push && git push --follow-tags",
    "publish:beta": "yarn && yarn validate && yarn package && npm publish --folder dist --tag beta",
    "release:beta": "npm version prerelease -m \"chore(update): prelease %s β\"",
    "release:patch": "git checkout master && npm version patch -m \"chore(update): patch release %s 🐛 \"",
    "release:minor": "git checkout master && npm version minor -m \"chore(update): release %s 🚀\"",
    "release:major": "git checkout master && npm version major -m \"chore(update): major release %s 💥 \"",
    "fix-vulnerabilities": "npx yarn-audit-fix && npx browserslist --update-db"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/fs-extra": "^11.0.4",
    "auto-changelog": "^2.6.0",
    "copyfiles": "^2.4.1",
    "fs-extra": "^11.3.6",
    "husky": "^9.1.7",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1"
  },
  "bin": {
    "package-version-info": "zig-out/bin/version_info"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=24 <26",
    "npm": "please-use-yarn"
  },
  "homepage": "https://github.com/Celtian/package-version-info",
  "repository": {
    "url": "git+https://github.com/Celtian/package-version-info.git",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/Celtian/package-version-info/issues"
  },
  "auto-changelog": {
    "remote": "none",
    "commitUrl": "https://github.com/Celtian/package-version-info/commit/{id}",
    "issueUrl": "https://github.com/Celtian/package-version-info/issues/{id}",
    "mergeUrl": "https://github.com/Celtian/package-version-info/pull/{id}",
    "compareUrl": "https://github.com/Celtian/package-version-info/compare/{from}...{to}"
  },
  "keywords": [
    "version",
    "info",
    "typescript",
    "zig",
    "package"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {}
}
